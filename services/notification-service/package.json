{
  "name": "@kinga/notification-service",
  "version": "1.0.0",
  "description": "KINGA Notification Service - Sends notifications via email, SMS, and push",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": ["kafka", "notifications", "microservice"],
  "author": "Tavonga Shoko",
  "license": "MIT",
  "dependencies": {
    "@kinga/events": "file:../../shared/events",
    "kafkajs": "^2.2.4",
    "zod": "^3.22.4",
    "nanoid": "^5.0.4",
    "prom-client": "^15.1.0",
    "express": "^4.18.2",
    "nodemailer": "^6.9.7",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^6.4.14",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0"
  }
}
